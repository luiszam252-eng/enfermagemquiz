    }

    function ganharXP(valor) {
      xp += valor;
      if (xp >= nivel * 50) {
        nivel++;
        conquistas.push("Subiu para nível " + nivel);
      }
      salvarProgresso();
      atualizarStatus();
    }

    function ganharMoedas(valor) {
      moedas += valor;
      if (moedas >= 500 && !conquistas.includes("Acumulou 500 moedas")) {
        conquistas.push("Acumulou 500 moedas");
      }
      salvarProgresso();
      atualizarStatus();
    }

    function comprarItem(item, custo) {
      if (moedas >= custo) {
        moedas -= custo;
        conquistas.push("Comprou " + item);
        alert("Você comprou: " + item);
      } else {
        alert("Moedas insuficientes!");
      }
      salvarProgresso();
      atualizarStatus();
    }

    function salvarProgresso() {
      localStorage.setItem("xp", xp);
      localStorage.setItem("nivel", nivel);
      localStorage.setItem("moedas", moedas);
      localStorage.setItem("conquistas", JSON.stringify(conquistas));
    }

    function iniciarCampanha() { iniciarQuiz(10, "Campanha"); }
    function iniciarSimulado() { iniciarQuiz(20, "Simulado"); }
    function iniciarTreino() { iniciarQuiz(5, "Treino"); }
    function iniciarDesafio() { iniciarQuiz(1, "Desafio Diário"); }

    function iniciarQuiz(qtd, modo) {
      document.getElementById("menu").style.display = "none";
      document.getElementById("quiz").style.display = "block";
      questoesSelecionadas = bancoQuestoes.sort(() => 0.5 - Math.random()).slice(0, qtd);
      questaoAtual = 0;
      pontuacao = 0;
      mostrarQuestao();
    }

    function mostrarQuestao() {
      const q = questoesSelecionadas[questaoAtual];
      document.getElementById("pergunta").innerText = q.Pergunta;
      const altDiv = document.getElementById("alternativas");
      altDiv.innerHTML = "";
      q.Alternativas.forEach(alt => {
        const btn = document.createElement("div");
        btn.className = "alternativa";
        btn.innerText = alt;
        btn.onclick = () => verificarResposta(alt, q);
        altDiv.appendChild(btn);
      });
      document.getElementById("feedback").innerText = "";
      document.getElementById("proxima").style.display = "none";
    }

    function verificarResposta(resposta, q) {
      if (resposta === q.Resposta) {
        pontuacao++;
        ganharXP(10);
        ganharMoedas(5);
        document.getElementById("feedback").innerText = "✅ Correto! " + q.Explicacao;
      } else {
        document.getElementById("feedback").innerText = "❌ Errado. " + q.Explicacao;
      }
      document.getElementById("proxima").style.display = "inline-block";
    }

    document.getElementById("proxima").onclick = () => {
      questaoAtual++;
      if (questaoAtual < questoesSelecionadas.length) {
        mostrarQuestao();
      } else {
        finalizarQuiz();
      }
    };

